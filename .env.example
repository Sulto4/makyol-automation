# Application Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=pdfextractor

# Database Pool Configuration
DB_POOL_MIN=2
DB_POOL_MAX=10

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# API Configuration
API_PREFIX=/api
CORS_ORIGIN=http://localhost:3000

# Pipeline Service Configuration
# Local development: http://localhost:8001
# Docker internal:   http://pipeline:8001
PIPELINE_URL=http://localhost:8001

# AI Configuration
# OpenRouter API key for Vision AI document processing
OPENROUTER_API_KEY=your_openrouter_api_key_here
# AI model to use for document analysis (e.g., google/gemini-2.0-flash-001)
AI_MODEL=google/gemini-2.0-flash-001

# Authentication (JWT)
# Generate a strong secret with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_random_32_byte_hex_string
JWT_EXPIRES_IN=7d
