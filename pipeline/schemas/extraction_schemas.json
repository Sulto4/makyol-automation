    "ISO": {
      "required_fields": [
        "companie",
        "material"
      ],
      "optional_fields": [
        "data_expirare",
        "producator",
        "distribuitor",
        "adresa_producator",
        "adresa_distribuitor"
      ],
      "validation_rules": {
        "companie": {
          "max_length": 80,
          "no_comma_lists": true
        },
        "material": {
          "max_length": 300,
          "not_generic": true
        },
        "data_expirare": {
          "format": "DD.MM.YYYY"
        },
        "adresa_producator": {
          "max_length": 250
        },
        "adresa_distribuitor": {
