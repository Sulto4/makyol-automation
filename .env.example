# Application Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=pdfextractor

# Database Pool Configuration
DB_POOL_MIN=2
DB_POOL_MAX=10

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# API Configuration
API_PREFIX=/api

# Allowed CORS origins (comma-separated). In production, the frontend is served
# by nginx same-origin with /api, so only add origins here for non-browser clients
# or alternate dev setups. Example:
#   CORS_ORIGIN=https://makyol-beta.example.com,http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Public URL — used only for documentation/logging; nginx terminates the subdomain.
# Example: https://makyol-beta.example.com
PUBLIC_URL=http://localhost

# Pipeline Service Configuration
# Local development: http://localhost:8001
# Docker internal:   http://pipeline:8001
PIPELINE_URL=http://localhost:8001

# AI Configuration
# OpenRouter API key for Vision AI document processing (required in production)
OPENROUTER_API_KEY=your_openrouter_api_key_here
# AI model to use for document analysis (e.g., google/gemini-2.5-flash)
AI_MODEL=google/gemini-2.5-flash

# Authentication (JWT) — required in production (docker-compose enforces)
# Generate a strong secret with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_random_32_byte_hex_string
JWT_EXPIRES_IN=7d

# Gate the public POST /api/auth/register endpoint.
# Default: false (closed beta — admin creates users via /admin/users).
# Set to true TEMPORARILY to seed the first admin account, then flip back to false.
REGISTER_ENABLED=false

# Shared secret for service-to-service auth. The Python pipeline sends this
# value as Bearer when calling protected backend routes (e.g. GET /api/settings
# on hot-reload). Must be ≥16 chars. Generate with: openssl rand -hex 32
INTERNAL_API_TOKEN=

# Bootstrap admin — consumed by scripts/create-admin.ts (run once at deploy)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=choose-a-strong-one
