# Application Configuration
APP_NAME="Makyol Compliance API"
APP_VERSION="1.0.0"
ENVIRONMENT="development"
DEBUG=true

# Server Configuration
HOST="0.0.0.0"
PORT=8000

# API Security
# Generate secure API keys and add them here (comma-separated)
# Example: openssl rand -hex 32
API_KEYS="your-secure-api-key-here,another-api-key-here"

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# CORS Configuration
CORS_ORIGINS="http://localhost:3000,http://localhost:8080"
CORS_ALLOW_CREDENTIALS=true

# Database Configuration (for future use)
# DATABASE_URL="postgresql://user:password@localhost:5432/compliance_db"

# Logging
LOG_LEVEL="INFO"
